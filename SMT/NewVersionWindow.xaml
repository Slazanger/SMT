<Window x:Class="SMT.NewVersionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource NewVer_Title}" Height="300" Width="400" ResizeMode="NoResize" Loaded="Window_Loaded" WindowStartupLocation="CenterOwner">
    <Grid>
        <ScrollViewer>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="{DynamicResource NewVer_New}" FontWeight="Bold" />
                    <Label Content="{Binding NewVersion}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Label Content="{DynamicResource NewVer_Cur}" FontWeight="Bold" />
                    <Label Content="{Binding CurrentVersion}" />
                </StackPanel>
                <Separator />
                <Label Content="{DynamicResource NewVer_Notes}" FontWeight="Bold" />
                <Label Content="{Binding ReleaseInfo}" />
                <Separator />
                <Label>
                    <Hyperlink NavigateUri="{Binding ReleaseURL}" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="{DynamicResource NewVer_Down}" />
                    </Hyperlink>
                </Label>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>