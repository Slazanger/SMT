<Window x:Class="SMT.CharactersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:SMT"
        xmlns:eveData="clr-namespace:SMT.EVEData;assembly=EVEData"
        mc:Ignorable="d"
        Closed="Window_Closed"
        Loaded="Window_Loaded"
        Title="{DynamicResource CharWin_Title}" Height="450" Width="750" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ObjectDataProvider x:Key="navigationEnumData" MethodName="GetValues" ObjectType="{x:Type System:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="eveData:RoutingMode" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>
    <Grid Background="{DynamicResource ListBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <ListView x:Name="characterLV"  Grid.Row="0" BorderBrush="Black"   SelectionChanged="characterLV_Selected" Margin="4">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <WrapPanel>
                        <Image Source="{Binding PortraitLocation}" Width="32" Height="32" Margin="1" />
                        <TextBlock Text="{Binding Name}" FontSize="16" />
                    </WrapPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button DockPanel.Dock="Bottom" Content="{DynamicResource CharWin_BtnAdd}" Grid.Row="1" Click="AddCharacter_Click" Margin="4" />

        <Grid x:Name="characterInfoGrid" Grid.Column="1" Grid.RowSpan="2" Visibility="Hidden" Background="{DynamicResource ListBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50*" />
                <ColumnDefinition Width="50*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="125" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
                <RowDefinition Height="25" />
            </Grid.RowDefinitions>

            <Image Source="{Binding PortraitLocation}" Width="120" Height="120" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left" Margin="10" />
            <StackPanel Orientation="Vertical" Grid.Row="0" Grid.Column="1" Margin="-40,30" Grid.RowSpan="2">
                <TextBlock Text="{Binding Name}" FontSize="24" Foreground="White" />

                <TextBlock FontSize="14" Foreground="LightGray">
                                    <Run Text="{Binding CorporationName, FallbackValue='????'}" />
                                    <Run Text=" [" />
                                    <Run Text="{Binding CorporationTicker, FallbackValue='????'}" />
                                    <Run Text="]" />
                </TextBlock>
                <TextBlock FontSize="14" Foreground="LightGray">
                                    <Run Text="{Binding AllianceName, FallbackValue='No Alliance'}" />
                                    <Run Text=" [" />
                                    <Run Text="{Binding AllianceTicker , FallbackValue=''}" />
                                    <Run Text="]" />
                </TextBlock>

                <TextBlock FontSize="14" Foreground="LightGray">
                                   <Run Text="{Binding Location, FallbackValue='Unknown Location'}" />
                </TextBlock>

                <TextBlock Text=" " />

                <TextBlock Margin="0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ESILinked}" Value="True">
                                    <Setter Property="Text" Value="{DynamicResource CharWin_Auth}" />
                                    <Setter Property="Foreground" Value="Green" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ESILinked}" Value="False">
                                    <Setter Property="Text" Value="{DynamicResource CharWin_Unauth}" />
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                    <Setter Property="Text" Value="{DynamicResource CharWin_Online}" />
                                    <Setter Property="Foreground" Value="LightGray" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                    <Setter Property="Text" Value="{DynamicResource CharWin_Offline}" />
                                    <Setter Property="Foreground" Value="DarkGray" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <GroupBox Header="{DynamicResource CharWin_NavOpt}" Grid.Row="1" Grid.RowSpan="10" BorderBrush="DarkGray" Margin="5">
                <StackPanel Margin="4">
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <Label Content="{DynamicResource CharWin_AutoPilot}" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource navigationEnumData}}" SelectedItem="{Binding NavigationMode, Mode=TwoWay}" Margin="2" Width="140"  Background="Black" />
                    </StackPanel>
                    <CheckBox IsChecked="{Binding UseAnsiblexGates}"  HorizontalAlignment="Left" Content="{DynamicResource CharWin_UseAns}" Margin="4" />
                    <CheckBox IsChecked="{Binding UseTheraRouting}"  HorizontalAlignment="Left" Content="{DynamicResource CharWin_UseThera}" Margin="4" />
                    <CheckBox IsChecked="{Binding UseTurnurRouting}"  HorizontalAlignment="Left" Content="{DynamicResource CharWin_UseTurnur}" Margin="4" />
                    <CheckBox IsChecked="{Binding UseZarzakhRouting}"  HorizontalAlignment="Left" Content="{DynamicResource CharWin_UseZarzakh}" Margin="4" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource CharWin_DangerGrp}"  Grid.Column="1" Grid.Row="1" Grid.RowSpan="4" BorderBrush="DarkGray" Margin="5">
                <StackPanel Margin="4">
                    <CheckBox IsChecked="{Binding DangerZoneActive}" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Checked="dangerZoneEnabled_Checked" Content="{DynamicResource CharWin_DangerEn}" Margin="4" />
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <xctk:IntegerUpDown Value="{Binding DangerZoneRange}" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0" Width="45" Minimum="1" Maximum="6" Background="Transparent"  Foreground="White" ValueChanged="dangerzone_ValueChanged" />
                        <Label Content="{DynamicResource CharWin_DangerSize}" Grid.Column="0" Grid.Row="5" HorizontalAlignment="Right" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource CharWin_NotifGrp}" Grid.Column="1" Grid.Row="5" Grid.RowSpan="6" BorderBrush="DarkGray" Margin="5">
                <StackPanel Margin="4">
                    <CheckBox IsChecked="{Binding ObservatoryDecloakWarningEnabled}" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Content="{DynamicResource CharWin_ObsDec}" Margin="4" />
                    <CheckBox IsChecked="{Binding GateDecloakWarningEnabled}" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Content="{DynamicResource CharWin_GateDec}" Margin="4" />
                    <CheckBox IsChecked="{Binding DecloakWarningEnabled}" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Content="{DynamicResource CharWin_OthDec}" Margin="4" />
                    <CheckBox IsChecked="{Binding CombatWarningEnabled}" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Content="{DynamicResource CharWin_Combat}" Margin="4" />
                </StackPanel>
            </GroupBox>

            <StackPanel Grid.Column="1" Grid.Row="11" Orientation="Horizontal"  HorizontalAlignment="Right">
                <Button Content="↓" Width="20" VerticalAlignment="Center"  Margin="4,0" x:Name="moveDownBtn" Click="MoveDownBtn_OnClick" />
                <Button Content="↑" Width="20" VerticalAlignment="Center"  Margin="4,0" x:Name="moveUpBtn" Click="MoveUpBtn_OnClick" />
                <Button Content="{DynamicResource CharWin_BtnDel}" Width="100" VerticalAlignment="Center"   Margin="20,0" x:Name="deleteBtn" Click="deleteBtn_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>